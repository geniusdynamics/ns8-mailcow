[Unit]
Description=Podman  ofelia-mailcow-app.service
BindsTo=mailcow.service
After=mailcow.service sogo-mailcow-app.service dovecot-mailcow-app.service

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
EnvironmentFile=%S/state/environment
EnvironmentFile=-%S/state/smarthost.env
WorkingDirectory=%S/state
Restart=always
TimeoutStopSec=70
ExecStartPre=/bin/mkdir -p tmp
ExecStartPre=/bin/rm -f %t/ofelia-mailcow-app.pid %t/ofelia-mailcow-app.ctr-id
ExecStartPre=-runagent discover-smarthost
ExecStart=/usr/bin/podman run --conmon-pidfile %t/ofelia-mailcow-app.pid  --cidfile %t/ofelia-mailcow-app.ctr-id --cgroups=no-conmon  --pod-id-file %t/mailcow.pod-id --replace -d --name  ofelia-mailcow-app   \
    --volume run-dockersock:/var/run/docker.sock:ro,z   \
    --env-file ofelia-mailcow.env  ${OFELIA_IMAGE}
ExecStop=/usr/bin/podman stop --ignore --cidfile %t/ofelia-mailcow-app.ctr-id -t 10
ExecReload=/usr/bin/podman kill -s HUP ofelia-mailcow-app
SyslogIdentifier=%u
ExecStopPost=/usr/bin/podman rm --ignore -f --cidfile %t/ofelia-mailcow-app.ctr-id
PIDFile=%t/ofelia-mailcow-app.pid
Type=forking

[Install]
WantedBy=default.target
