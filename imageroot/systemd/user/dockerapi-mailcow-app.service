[Unit]
Description=Podman  dockerapi-mailcow-app.service
After=mailcow.service

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
EnvironmentFile=%S/state/environment
EnvironmentFile=-%S/state/smarthost.env
WorkingDirectory=%S/state
Restart=always
TimeoutStopSec=70
ExecStartPre=/bin/mkdir -p tmp
ExecStartPre=/bin/rm -f %t/dockerapi-mailcow-app.pid %t/dockerapi-mailcow-app.ctr-id
ExecStartPre=-runagent discover-smarthost
ExecStart=/usr/bin/podman run --conmon-pidfile %t/dockerapi-mailcow-app.pid  --cidfile %t/dockerapi-mailcow-app.ctr-id --cgroups=no-conmon  --pod-id-file %t/mailcow.pod-id --replace -d --name  dockerapi-mailcow-app   \
    --volume run-dockersock:/var/run/docker.sock:ro,z \
    --env-file dockerapi-mailcow.env  ${DOCKERAPI_IMAGE}
ExecStop=/usr/bin/podman stop --ignore --cidfile %t/dockerapi-mailcow-app.ctr-id -t 10
ExecReload=/usr/bin/podman kill -s HUP dockerapi-mailcow-app
SyslogIdentifier=%u
ExecStopPost=/usr/bin/podman rm --ignore -f --cidfile %t/dockerapi-mailcow-app.ctr-id
PIDFile=%t/dockerapi-mailcow-app.pid
Type=forking

[Install]
WantedBy=default.target
