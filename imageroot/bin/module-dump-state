set -e

if ! systemctl --user -q is-active mailcow.service; then
	exit 0
fi

		podman exec mysql-mailcow-app mysqldump \
        --databases mysql-mailcow \
        --default-character-set=utf8mb4 \
        --skip-dump-date \
        --ignore-table=mysql.event \
        --single-transaction \
        --quick \
        --add-drop-table  > mysql-mailcow.sql
		
